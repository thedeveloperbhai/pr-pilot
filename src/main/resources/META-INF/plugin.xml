<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.vitiquest.peer-review</id>

    <name>PR Pilot</name>

    <vendor url="https://www.vitiquest.com">Vitiquest</vendor>

    <description><![CDATA[
        <b>PR Pilot</b> — Review GitHub and Bitbucket Cloud Pull Requests from within IntelliJ IDEA.<br/>
        Features: Browse open PRs, view diffs, generate AI summaries, approve or decline PRs.<br/>
        Supports per-project AI skill files under <code>.idea/pr-pilot/skills/</code>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Tool Window -->
        <toolWindow
            id="PR Pilot"
            anchor="right"
            factoryClass="com.vitiquest.peerreview.ui.PRToolWindowFactory"
            icon="AllIcons.Vcs.Branch"/>

        <!-- Persistent Settings -->
        <applicationService
            serviceImplementation="com.vitiquest.peerreview.settings.PluginSettings"/>

        <!-- Skills service (project-scoped — reads .idea/pr-pilot/skills/*.md) -->
        <projectService
            serviceImplementation="com.vitiquest.peerreview.skills.PRPilotSkillsService"/>

        <!-- Seeds default skill files when a project is first opened -->
        <postStartupActivity
            implementation="com.vitiquest.peerreview.skills.PRPilotSkillsStartupActivity"/>

        <!-- Dedicated full-size settings window for the plugin -->
        <applicationConfigurable
            id="com.vitiquest.peerreview.settings.root"
            displayName="PR Pilot"
            instance="com.vitiquest.peerreview.settings.PRPilotSettingsConfigurable"/>

        <!-- Notification group for balloon messages -->
        <notificationGroup id="PR Pilot"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

    </extensions>
</idea-plugin>

